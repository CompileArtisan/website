---
import MainLayout from '../layouts/MainLayout.astro';
import Keybindings from '../components/Keybindings.astro';
import Icon from '../components/Icon';
import { getCollection } from 'astro:content';
import { xposts } from '../data/xposts';

const blogPosts = await getCollection('blog');

type FeedItem =
  | { kind: 'blog'; title: string; date: Date; slug: string; description?: string; tags: string[] }
  | { kind: 'xpost'; id: string; text: string; date: Date; url: string; tags: string[] }

const feedItems: FeedItem[] = [
  ...blogPosts.map((post) => ({
    kind: 'blog' as const,
    title: post.data.title,
    date: new Date(post.data.date),
    slug: post.slug,
    description: post.data.description,
    tags: post.data.tags ?? [],
  })),
...xposts.map((xp) => ({
  kind: 'xpost' as const,
  id: xp.id,
  text: xp.text,
  date: new Date(xp.date),
  url: xp.url,
  tags: xp.tags ?? [],
})),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const allTags = Array.from(
  new Set(
    feedItems.flatMap((item) => item.tags ?? [])
  )
).sort();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<MainLayout title="Feed - CompileArtisan">
  <div class="main-content">
    <div class="left-panel">
      <div class="filter-bar">
        <button class="filter-btn active" data-filter="all">all</button>
        <button class="filter-btn" data-filter="kind:blog">blog</button>
        <button class="filter-btn" data-filter="kind:xpost">x post</button>
        {allTags.map(tag => (
          <button class="filter-btn" data-filter={`tag:${tag}`}>{tag}</button>
        ))}
      </div>

      <ul class="feed-list" id="feed-list">
        {feedItems.length === 0 ? (
          <li class="empty">Nothing here yet.</li>
        ) : feedItems.map((item) => (
<li
  class={`feed-item feed-item--${item.kind}`}
  data-kind={item.kind}
  data-tags={(item.tags ?? []).join(',')}
>
            {item.kind === 'blog' ? (
              <a href={`/blogs/${item.slug}`} class="icon-link feed-link">
                <span class="feed-meta">
                  <span class="feed-type feed-type--blog">blog</span>
                  <span class="feed-date">{formatDate(item.date)}</span>
                  {(item.tags ?? []).length > 0 && (
                    <span class="feed-tags">
                      {item.tags.map(tag => (
                        <span class="feed-tag">{tag}</span>
                      ))}
                    </span>
                  )}
                </span>
                <span class="feed-body">
                  <Icon name="hyperlink" />
                  <span class="feed-title">{item.title}</span>
                </span>
              </a>
            ) : (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="icon-link feed-link">
<span class="feed-meta">
  <span class="feed-type feed-type--xpost">x post</span>
  <span class="feed-date">{formatDate(item.date)}</span>
  {(item.tags ?? []).length > 0 && (
    <span class="feed-tags">
      {item.tags.map(tag => <span class="feed-tag">{tag}</span>)}
    </span>
  )}
</span>
                <span class="feed-body">
                  <Icon name="x" />
                  <span class="feed-title">{item.text}</span>
                </span>
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
    <div class="right-panel">
      <div class="right-panel-top">
        <p>Everything I've written — blog posts and X posts — newest first.</p>
      </div>
      <Keybindings />
    </div>
  </div>
</MainLayout>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding: 1em 2em 0.5em;
    border-bottom: 2px solid var(--color-border);
  }

  .filter-btn {
    font-family: var(--font-family-primary);
    font-size: var(--font-size-small);
    background: none;
    border: 2px solid var(--color-text-secondary);
    color: var(--color-text-secondary);
    padding: 2px 10px;
    cursor: pointer;
    text-transform: lowercase;
    transition: all var(--transition-duration) ease;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-text-primary);
  }

  .feed-list {
    padding: 2em;
    list-style: none;
    margin: 0;
  }

  .feed-item {
    margin: var(--spacing-xl) 0;
    font-size: var(--font-size-large);
  }

  .feed-item.hidden {
    display: none;
  }

  .feed-link {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    text-decoration: none;
    color: var(--color-text-secondary);
  }

  .feed-link:hover {
    color: var(--color-primary);
  }

  .feed-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8em;
    font-size: 0.55em;
    opacity: 0.75;
    color: var(--color-text-secondary);
  }

  .feed-type {
    padding: 1px 6px;
    font-size: 0.95em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feed-type--blog {
    background-color: var(--color-primary);
    color: var(--color-text-primary);
  }

  .feed-type--xpost {
    background-color: var(--color-text-secondary);
    color: var(--color-secondary);
  }

  .feed-date {
    color: var(--color-text-secondary);
  }

  .feed-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .feed-tag {
    border: 1px solid var(--color-text-secondary);
    padding: 0px 6px;
    font-size: 0.9em;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .feed-body {
    display: flex;
    align-items: flex-start;
    gap: 0.5em;
  }

  .feed-body :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15em;
    width: 0.8em;
    height: 0.8em;
  }

  .feed-title {
    line-height: 1.4;
  }

  .feed-item--xpost .feed-title {
    font-size: 0.85em;
    opacity: 0.9;
  }

  .empty {
    color: var(--color-text-secondary);
    opacity: 0.6;
    padding: 2em;
    font-size: var(--font-size-medium);
  }

  @media screen and (max-width: 768px) {
    .filter-bar {
      padding: 0.75em 1em 0.5em;
    }

    .feed-list {
      padding: 1em;
    }

    .feed-item {
      font-size: var(--font-size-medium);
      margin: var(--spacing-xxl) 0;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.feed-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'all';

      items.forEach(item => {
        const kind = item.dataset.kind ?? '';
        const tags = item.dataset.tags ? item.dataset.tags.split(',') : [];

        let visible = false;
        if (filter === 'all') {
          visible = true;
        } else if (filter.startsWith('kind:')) {
          visible = kind === filter.slice(5);
        } else if (filter.startsWith('tag:')) {
          visible = tags.includes(filter.slice(4));
        }

        item.classList.toggle('hidden', !visible);
      });
    });
  });

  import { initHorizontalNavigation } from '../scripts/navigation';
  import { initVerticalNavigation } from '../scripts/navigation';

  initHorizontalNavigation();
  initVerticalNavigation();
</script>
